# ==================== MyVideo 配置文件 ====================

# ==================== 必填配置（必须填写，否则无法启动）====================
MYVIDEO_ROOT=/data/myvideo
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=myvideo
DATABASE_PASSWORD=myvideo_password
DATABASE_NAME=myvideo_db
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis123
SECRET_KEY=myvideo_secret_key_change_me_in_prod

# ==================== 选填配置（有默认值，可不填）====================

# 安全 / JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库
DATABASE_ECHO=false

# 应用服务器
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# 分享设置
SHARE_BASE_URL=

# 文件存储目录（相对于 MYVIDEO_ROOT）
STATIC_SUBDIR=static
UPLOADS_SUBDIR=static/videos/uploads
PROCESSED_SUBDIR=static/videos/processed
THUMBNAILS_SUBDIR=static/thumbnails
AVATARS_SUBDIR=static/avatars
DATA_SUBDIR=data

# URL 路径前缀
THUMBNAILS_URL=/static/thumbnails
VIDEOS_URL=/static/videos
AVATARS_URL=/static/avatars

# 上传限制
MAX_UPLOAD_SIZE_MB=2048

# CORS 跨域设置
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Celery 任务队列（留空则使用 Redis）
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=

# 敏感词过滤（留空使用默认路径）
SENSITIVE_WORDS_FILE=

# 冷存储配置
COLD_STORAGE_ENABLED=true
COLD_STORAGE_TRIGGER_DAYS=5
COLD_STORAGE_TRIGGER_VIEWS=5
COLD_STORAGE_PATH_ROOT=/data/myvideo/cold_storage

# 转码队列优先级
TRANSCODE_CONCURRENCY=4
TRANSCODE_AGING_RATE=0.5
TRANSCODE_MAX_PRIORITY=40
TRANSCODE_VIP_BASE_PRIORITY=10
TRANSCODE_PAID_BASE_PRIORITY=30
TRANSCODE_BUMP_COST=5

# 存储迁移配置
STORAGE_MIGRATION_DELAY=0.2

# 存储后端（local / s3 / oss）
STORAGE_BACKEND=local

# S3 配置（STORAGE_BACKEND=s3 时使用）
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=us-east-1
S3_PREFIX=

# 阿里云 OSS 配置（STORAGE_BACKEND=oss 时使用）
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET_NAME=
OSS_REGION_NAME=cn-hangzhou
OSS_PREFIX=
