# ==================== MyVideo 配置文件 ====================
# 请将此项文件复制为 .env 并根据实际情况修改

# ==================== 基础配置 ====================
# 项目根目录（必须是绝对路径）
MYVIDEO_ROOT=/data/myvideo

# ==================== 数据库 PostgreSQL ====================
# 数据库主机地址
DATABASE_HOST=localhost
# 数据库端口
DATABASE_PORT=5432
# 数据库用户名
DATABASE_USER=myvideo
# 数据库密码
DATABASE_PASSWORD=myvideo_password
# 数据库名称
DATABASE_NAME=myvideo_db
# 是否打印 SQL 日志（调试用）
DATABASE_ECHO=false

# ==================== Redis 缓存 ====================
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 数据库编号
REDIS_DB=0
# Redis 密码（无密码则留空）
REDIS_PASSWORD=redis123

# ==================== 安全 / JWT ====================
# JWT 密钥（生产环境必须修改为复杂随机字符串）
SECRET_KEY=myvideo_secret_key_change_me_in_prod
# JWT 加密算法
ALGORITHM=HS256
# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== 应用服务器 ====================
# 服务监听地址
APP_HOST=0.0.0.0
# 服务监听端口
APP_PORT=8000
# 调试模式（生产环境设为 false）
APP_DEBUG=false

# ==================== 文件存储目录（相对于 MYVIDEO_ROOT）====================
# 静态文件目录
STATIC_SUBDIR=static
# 用户上传的原始视频目录
UPLOADS_SUBDIR=static/videos/uploads
# 转码后的视频目录
PROCESSED_SUBDIR=static/videos/processed
# 视频缩略图目录
THUMBNAILS_SUBDIR=static/thumbnails
# 用户头像目录
AVATARS_SUBDIR=static/avatars
# 数据文件目录
DATA_SUBDIR=data

# ==================== URL 路径前缀 ====================
# 缩略图访问路径
THUMBNAILS_URL=/static/thumbnails
# 视频访问路径
VIDEOS_URL=/static/videos
# 头像访问路径
AVATARS_URL=/static/avatars

# ==================== CORS 跨域设置 ====================
# 允许访问的域名（* 表示全部，允许多个用逗号分隔）
CORS_ORIGINS=*
# 是否允许携带凭证
CORS_CREDENTIALS=true
# 允许的 HTTP 方法
CORS_METHODS=*
# 允许的 HTTP 头
CORS_HEADERS=*

# ==================== Celery 任务队列 ====================
# Celery 消息代理 URL（留空则使用 Redis）
CELERY_BROKER_URL=
# Celery 结果后端 URL（留空则使用 Redis）
CELERY_RESULT_BACKEND=

# ==================== 日志配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# 日志文件路径（留空则在项目根目录生成 server.log）
LOG_FILE=

# ==================== 敏感词过滤 ====================
# 敏感词文件路径（留空使用默认路径）
SENSITIVE_WORDS_FILE=

# ==================== 冷存储配置 ====================
# 是否启用冷存储功能（true/false）
COLD_STORAGE_ENABLED=false
# 触发冷存储的天数（上传超过此天数）
COLD_STORAGE_TRIGGER_DAYS=180
# 触发冷存储的播放量阈值（低于此播放量）
COLD_STORAGE_TRIGGER_VIEWS=10

# ==================== 存储迁移配置 ====================
# 迁移间隔时间（秒），控制迁移速度避免 CPU/磁盘 占用过高
# 值越大速度越慢，0 表示不限制
# 推荐值：0.1（快）、0.5（平衡）、1.0（慢）
STORAGE_MIGRATION_DELAY=0.5
