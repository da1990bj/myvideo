# MyVideo Configuration
# Copy this file to .env and customize for your environment

# ===================
# Project Paths
# ===================
# Override auto-detected project root (useful for containers/testing)
# MYVIDEO_ROOT=/path/to/myvideo

# ===================
# Database (PostgreSQL)
# ===================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=myvideo
DATABASE_PASSWORD=myvideo_password
DATABASE_NAME=myvideo_db
# Or use full URL (overrides individual settings above):
# DATABASE_URL=postgresql://myvideo:myvideo_password@localhost:5432/myvideo_db

# ===================
# Redis
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Or use full URL:
# REDIS_URL=redis://localhost:6379/0

# ===================
# Security / JWT
# ===================
# IMPORTANT: Change this in production!
SECRET_KEY=myvideo_secret_key_change_me_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================
# Application
# ===================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
# LOG_FILE=/path/to/server.log

# ===================
# FFmpeg (if not in PATH)
# ===================
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# ===================
# Sensitive Words
# ===================
# SENSITIVE_WORDS_FILE=/data/myvideo/data/sensitive_words.txt
